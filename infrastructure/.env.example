# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=pulsecrm
POSTGRES_PASSWORD=pulsecrm_dev

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=pulsecrm
RABBITMQ_DEFAULT_PASS=pulsecrm_dev

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CONNECTION=redis:6379

# ── Seq ───────────────────────────────────────────────────────────────────────
SEQ_URL=http://seq:5341

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here

# ── Service URLs (internal docker network) ────────────────────────────────────
DEALS_URL=http://deals:5001
SCORING_URL=http://scoring:5002
NOTIFICATIONS_URL=http://notifications:5003
SUMMARIZATION_URL=http://summarization:5004
KEYCLOAK_URL=http://keycloak:8080
